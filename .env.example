# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/sidekick

# Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Hack Club Auth OAuth 2.0
# Required scopes: openid profile email slack_id
HCA_CLIENT_ID=
HCA_CLIENT_SECRET=
HCA_REDIRECT_URI=http://localhost:5173/auth/callback

# Slack Bot Token (for fetching user profile pictures)
# Required scopes: users:read
SLACK_BOT_TOKEN=xoxb-

# Hackatime admin API key
HACKATIME_ADMIN_TOKEN=

# Airtable (Unified YSWS DB, read-only)
# Required PAT scopes: data.records:read
# Grant access to the Unified YSWS DB base (app3A5kJwYqxMLOgh)
AIRTABLE_PAT=
AIRTABLE_BASE_ID=app3A5kJwYqxMLOgh
AIRTABLE_TABLE_ID=tblzWWGUYHVH7Zyqf

# GitHub personal access token (classic) or fine-grained token
# Classic: repo scope (or no scope for public repos only, lower rate limit)
# Fine-grained: Contents (read-only) permission on relevant repos
GITHUB_TOKEN=

# Session cookie signing secret
SESSION_SECRET=

# Encryption key for storing tokens/secrets at rest (64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# HCB (Hack Club Bank) OAuth 2.0
# Required scopes: read write
# Register at: https://hcb.hackclub.com/api/v4/oauth/applications
HCB_CLIENT_ID=
HCB_CLIENT_SECRET=
HCB_REDIRECT_URI=http://localhost:5173/auth/hcb/callback

# Lapse program key (for authenticated timelapse access)
LAPSE_PROGRAM_KEY=
